	board = /obj/item/circuitboard/machine/quantumpad;
	pixel_x = -7;
	pixel_y = 8;
	name = "a conveniently placed quantum pad flatpack"
	},
/obj/item/paper{
	pixel_x = 12;
	default_raw_text = "Management decided that you guys need to attract more customers in a convenient, efficient, and especially <B>cost-cutting</B> method. Solution? Quantum pads! Honestly, I have no clue what the science behind this stuff is, all I care is that it basically links two places together. So, if you get a customer who you <B>think</B> could <B>potentially</B> bring others along, hand it over to them along with a multitool, make sure it is linked properly. As it turns out that the activity of plasma-operated vehicles on lavaland is much lower than we predicted, so we're hoping trying to expand our trade with spacefaring folks will bring in that extra revenue we want.<BR><BR>-Supply Manager, Jasper 'Jas' Statham";
	name = "Quantum Pad Shipment";
	pixel_y = -9
	},
/obj/item/multitool{
	pixel_x = 9;
	pixel_y = 5
	},
/obj/effect/decal/cleanable/wrapping,
